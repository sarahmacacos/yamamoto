<body>

    <header>
        <div class="container header-inner">
            <div class="logo">&lt;/&gt; Portal <strong>WebCode</strong></div>
            <nav>
                <button id="menuBtn">&#9776;</button>
                <ul id="menu">
                    <li><a href="#html">HTML</a></li>
                    <li><a href="#css">CSS</a></li>
